{
  "name": "openclaw-desktop",
  "version": "0.0.5",
  "description": "Windows-first Electron wrapper for OpenClaw with guided onboarding.",
  "main": "dist/main/main.js",
  "author": "",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:test": "node ./node_modules/typescript/bin/tsc -p tsconfig.main.json",
    "build:assets": "node scripts/copy-renderer.mjs",
    "build:renderer-react": "vite build --config vite.config.mjs",
    "build": "npm run clean && npm run build:main && npm run build:assets && npm run build:renderer-react",
    "dev": "npm run build && electron .",
    "dev:react": "npm run build && cross-env OPENCLAW_UI_EXPERIMENT=react electron .",
    "start": "electron .",
    "test": "npm run build:test && node --test tests/*.test.js",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "ai.openclaw.desktop",
    "productName": "OpenClaw Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/branding/openclaw_icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "assets/branding/openclaw_icon.ico",
      "uninstallerIcon": "assets/branding/openclaw_icon.ico"
    },
    "protocols": [
      {
        "name": "OpenClaw Desktop",
        "schemes": [
          "openclawdesktop"
        ]
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^22.13.8",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.24",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.575.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0"
  }
}
